<p>Wikinimous</p>
<h2 class="d-inline-flex gap-2"><%= @article.title %>
<div>
  <%= link_to edit_article_path(@article), class: "btn btn-sm btn-outline-secondary" do %>
    <i class="fa fa-pencil"></i>
  <% end %>

  <%= link_to article_path(@article), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" do %>
    <i class="fa fa-trash"></i>
  <% end %>
</div>
</h2>
<p><%= @article.content %></p>
<%= link_to "Back to articles", articles_path %>
